# ════════════════════════════════════════════════════════════════
# AlphaTheta v2 — 环境变量模板
#
# 使用方式:
#   cp .env.example .env
#   编辑 .env 填入你的 API Key
#
# Docker Compose 会自动读取同目录下的 .env 文件
# 对于 Docker 内部: DATABASE_URL 和 REDIS_URL 会被 compose 中的
# environment 覆盖 (localhost → 服务名 db/redis)
# ════════════════════════════════════════════════════════════════

# ══════════════════════════════════════
# 环境隔离
# ══════════════════════════════════════
# paper = 模拟盘 (默认, 使用 Tradier sandbox API)
# live  = 实盘 (使用 Tradier 实盘 Token, 真实资金!)
ENV_MODE=paper

# ══════════════════════════════════════
# 基础设施 — 数据库 & 缓存
# ══════════════════════════════════════
# 本地开发时使用 localhost; Docker 内部会被 compose 覆盖为服务名
# asyncpg 驱动: PostgreSQL 异步连接 (比 psycopg2 快 3~5x)
DATABASE_URL=postgresql+asyncpg://alpha:alpha@localhost:5432/alphatheta
REDIS_URL=redis://localhost:6379/0

# ══════════════════════════════════════
# 券商: Tradier
# ══════════════════════════════════════
# 申请: https://developer.tradier.com/ → 注册免费账号 → 获取 Sandbox Token
# Paper 模式使用 sandbox.tradier.com
# Live 模式使用 api.tradier.com
TRADIER_SANDBOX_TOKEN=
TRADIER_LIVE_TOKEN=
TRADIER_ACCOUNT_ID=

# ══════════════════════════════════════
# 市场数据: Finnhub
# ══════════════════════════════════════
# 申请: https://finnhub.io/register → 免费账号 → API Key
# 免费版: 60 req/min, 美股新闻 + 市场情绪
FINNHUB_API_KEY=

# ══════════════════════════════════════
# 行情降级: Yahoo Finance (免费, 无需 Key)
# ══════════════════════════════════════
# 当 Tradier Token 为空时自动启用
# 延迟约 15 分钟, IP 限速约 2000 req/hour
USE_YFINANCE_FALLBACK=true

# ══════════════════════════════════════
# 安全
# ══════════════════════════════════════
# Fernet 对称加密 Key — 用于加密存储敏感凭据
# 生成: python3 -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
ENCRYPTION_KEY=CHANGE_ME_32_BYTE_FERNET_KEY_BASE64

# JWT 签名密钥 (如启用 API 认证)
# 生成: python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET

# ══════════════════════════════════════
# 时钟校准
# ══════════════════════════════════════
# 交易系统对时间精度有严格要求
# 时钟偏差 > 5s 时触发告警
NTP_SERVER=time.google.com
MAX_CLOCK_DRIFT_SECONDS=5.0

# ══════════════════════════════════════
# CORS (跨域资源共享)
# ══════════════════════════════════════
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5500

# ══════════════════════════════════════
# 可观测性 (OpenTelemetry + Prometheus)
# ══════════════════════════════════════
OTEL_SERVICE_NAME=alphatheta-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_ENABLED=true

# ══════════════════════════════════════
# 日志
# ══════════════════════════════════════
LOG_LEVEL=INFO
